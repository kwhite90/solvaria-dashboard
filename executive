function applyDBAFilter() {
  const term = (document.getElementById('dba-search').value || '').toLowerCase();
  let list = dbaTeamData.slice();
  if (dbaFilter !== 'all') list = list.filter(d => d.tags.includes(dbaFilter));
  if (term) {
    list = list.filter(d => {
      const blob = [d.name, d.role, ...d.platforms, ...d.cloud, ...d.skills, ...d.industries, ...(d.certs||[]), ...(d.inProgressCerts||[])].join(' ').toLowerCase();
      return blob.includes(term);
    });
  }
  if (dbaViewMode === 'cards') renderDBACards(list);
  else renderDBAMatrix(list);
}

