    html += `
      <div class="consultant-card" onclick="openConsultantAssessment('${escapeAttr(c)}')" role="button" tabindex="0"
           onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();openConsultantAssessment('${escapeAttr(c)}')}"
           style="background: white; padding: 16px 18px; border-radius: 8px; box-shadow: var(--shadow-sm); border-left: 4px solid ${borderColor}; cursor: pointer; transition: all 0.2s;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
          <div style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; color: var(--navy); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.5px;">${escapeHtml(c)}</div>
          <span style="color: var(--gray-mid); font-size: 1rem; line-height: 1;">›</span>
        </div>
        <div style="display: flex; align-items: baseline; gap: 6px; margin-top: 4px;">
          <span style="font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--navy);">${formatHours(total)}</span>
          <span style="font-size: 0.85rem; color: var(--gray-mid);">/ ${targetHours}h target</span>
        </div>
        <div class="utilization-bar" style="max-width: 100%; margin: 6px 0 4px 0;">
          <div class="utilization-fill ${cls}" style="width: ${colorPct}%"></div>
        </div>
        <div style="font-size: 0.78rem; color: var(--gray-mid);">${pct.toFixed(0)}% utilized this month</div>
      </div>
    `;
  });
  html += `</div>`;
  
  wrap.innerHTML = html;
}

