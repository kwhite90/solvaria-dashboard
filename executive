// === Time Tracking date range state ===
let timeRange = {
  kind: 'this-month',  // 'this-week' | 'last-week' | 'this-month' | 'last-month' | 'last-30' | 'custom'
  from: '',            // YYYY-MM-DD
  to: '',              // YYYY-MM-DD
  entries: null,       // Cached time entries for the selected range
  loading: false,
  error: null
};

// Cache time entries fetched for ranges outside the current month
const timeRangeCache = {}; // key: "from|to", value: entries array

function getRangeDates(kind) {
  const today = new Date();
  const todayStr = formatLocalDate(today);
  
  if (kind === 'this-week') {
    const day = today.getDay();
    const offset = day === 0 ? -6 : 1 - day;
    const monday = new Date(today.getFullYear(), today.getMonth(), today.getDate() + offset);
    const sunday = new Date(monday.getFullYear(), monday.getMonth(), monday.getDate() + 6);
    return { from: formatLocalDate(monday), to: formatLocalDate(sunday) };
  }
  if (kind === 'last-week') {
    const day = today.getDay();
    const offset = day === 0 ? -6 : 1 - day;
    const thisMonday = new Date(today.getFullYear(), today.getMonth(), today.getDate() + offset);
    const lastMonday = new Date(thisMonday.getFullYear(), thisMonday.getMonth(), thisMonday.getDate() - 7);
    const lastSunday = new Date(lastMonday.getFullYear(), lastMonday.getMonth(), lastMonday.getDate() + 6);
    return { from: formatLocalDate(lastMonday), to: formatLocalDate(lastSunday) };
  }
  if (kind === 'this-month') {
    const y = today.getFullYear(), m = today.getMonth();
    const lastDay = new Date(y, m + 1, 0).getDate();
    return { 
      from: `${y}-${String(m+1).padStart(2,'0')}-01`, 
      to: `${y}-${String(m+1).padStart(2,'0')}-${String(lastDay).padStart(2,'0')}` 
    };
  }
  if (kind === 'last-month') {
    const y = today.getFullYear(), m = today.getMonth();
    const lastMonthDate = new Date(y, m - 1, 1);
    const ly = lastMonthDate.getFullYear(), lm = lastMonthDate.getMonth();
    const lastDay = new Date(ly, lm + 1, 0).getDate();
    return {
      from: `${ly}-${String(lm+1).padStart(2,'0')}-01`,
      to: `${ly}-${String(lm+1).padStart(2,'0')}-${String(lastDay).padStart(2,'0')}`
    };
  }
  if (kind === 'last-30') {
    const start = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 29);
    return { from: formatLocalDate(start), to: todayStr };
  }
  return { from: '', to: '' };
}

async function setTimeRange(kind) {
  const customWrap = document.getElementById('time-filter-custom');
  
  // Update active chip
  document.querySelectorAll('#time-range-chips .time-chip').forEach(b => {
    b.classList.toggle('active', b.dataset.range === kind);
  });
  
  if (kind === 'custom') {
    customWrap.style.display = 'flex';
    // Pre-fill custom inputs with the last applied range (or current month)
    document.getElementById('time-custom-from').value = timeRange.from || appData.monthFrom;
    document.getElementById('time-custom-to').value = timeRange.to || appData.monthTo;
    return; // Wait for Apply
  }
  customWrap.style.display = 'none';
  
  const { from, to } = getRangeDates(kind);
  timeRange.kind = kind;
  timeRange.from = from;
  timeRange.to = to;
  
  await loadTimeRangeEntries();
  renderTime();
}

async function applyCustomRange() {
  const from = document.getElementById('time-custom-from').value;
  const to = document.getElementById('time-custom-to').value;
  if (!from || !to) { alert('Please pick a from and to date.'); return; }
  if (from > to) { alert('"From" date must be on or before the "To" date.'); return; }
  
  timeRange.kind = 'custom';
  timeRange.from = from;
  timeRange.to = to;
  
  await loadTimeRangeEntries();
  renderTime();
}

async function loadTimeRangeEntries() {
  const { from, to } = timeRange;
  if (!from || !to) return;
  
  // If range is fully within the already-loaded current month, just filter client-side
  if (from >= appData.monthFrom && to <= appData.monthTo && appData.timeEntries && appData.timeEntries.length) {
    timeRange.entries = appData.timeEntries.filter(e => {
      return e.spent_date >= from && e.spent_date <= to;
    });
    timeRange.loading = false;
    timeRange.error = null;
    return;
  }
  
  // Check cache
  const cacheKey = from + '|' + to;
  if (timeRangeCache[cacheKey]) {
    timeRange.entries = timeRangeCache[cacheKey];
    timeRange.loading = false;
    timeRange.error = null;
    return;
  }
  
  // Need to fetch from Harvest
  if (!appData.harvestConfig || !appData.harvestConfig.token || !appData.harvestConfig.accountId) {
    timeRange.entries = null;
    timeRange.error = 'Harvest credentials not available';
    return;
  }
  
  timeRange.loading = true;
  timeRange.error = null;
  renderTime(); // Show loading state
  
  const headers = {
    'Authorization': `Bearer ${appData.harvestConfig.token}`,
    'Harvest-Account-Id': appData.harvestConfig.accountId,
    'User-Agent': 'Solvaria Executive Dashboard'
  };
  
  try {
    let allEntries = [];
    let page = 1;
    let hasMore = true;
    while (hasMore) {
      const url = `https://api.harvestapp.com/v2/time_entries?from=${from}&to=${to}&page=${page}&per_page=2000`;
      const resp = await fetch(url, { headers });
      if (!resp.ok) throw new Error(`Status ${resp.status}`);
      const data = await resp.json();
      allEntries = allEntries.concat(data.time_entries || []);
      const totalPages = data.total_pages || 1;
      hasMore = page < totalPages;
      page++;
    }
    
    timeRangeCache[cacheKey] = allEntries;
    timeRange.entries = allEntries;
    timeRange.loading = false;
    timeRange.error = null;
  } catch (err) {
    console.error('[Time Range] Fetch error:', err);
    timeRange.entries = null;
    timeRange.loading = false;
    timeRange.error = err.message || 'Failed to load';
  }
}

function formatRangeLabel(from, to) {
  if (!from || !to) return '';
  const fromDt = new Date(from + 'T12:00:00');
  const toDt = new Date(to + 'T12:00:00');
  const fmtOpts = { month: 'short', day: 'numeric', timeZone: 'UTC' };
  const sameYear = fromDt.getUTCFullYear() === toDt.getUTCFullYear();
  const fromStr = fromDt.toLocaleDateString('en-US', fmtOpts);
  const toStr = toDt.toLocaleDateString('en-US', fmtOpts);
  const yearStr = sameYear ? '' : `, ${toDt.getUTCFullYear()}`;
  return `${fromStr} – ${toStr}${yearStr}`;
}

function renderTime() {
  const cards = document.getElementById('time-summary-cards');
  const byClient = document.getElementById('time-by-client');
  
  if (!appData.harvestConfig || !appData.harvestConfig.token) {
    cards.innerHTML = '';
    byClient.innerHTML = '<div style="padding: 40px; text-align: center; color: var(--gray-mid);">Time tracking data is not currently available.</div>';
    return;
  }
  
  if (appData.loading || timeRange.loading) {
    cards.innerHTML = '<div style="padding: 30px; text-align: center; color: var(--gray-mid); grid-column: 1 / -1;">Loading...</div>';
    byClient.innerHTML = '';
    return;
  }
  
  if (appData.lastError) {
    cards.innerHTML = '';
    byClient.innerHTML = '<div style="padding: 40px; text-align: center; color: var(--gray-mid);">Time tracking data is temporarily unavailable. Please try refreshing.</div>';
    return;
  }
  
  // Initialize range on first render if not set
  if (!timeRange.from || !timeRange.to) {
    const { from, to } = getRangeDates('this-month');
    timeRange.from = from;
    timeRange.to = to;
    timeRange.kind = 'this-month';
  }
  
  // Determine which entries to use: prefer timeRange.entries if loaded; otherwise filter current month
  let entries = timeRange.entries;
  if (entries === null) {
    // Fall back to filtering current month
    if (!appData.timeEntries || appData.timeEntries.length === 0) {
      cards.innerHTML = '';
      byClient.innerHTML = '<div style="padding: 40px; text-align: center; color: var(--gray-mid);">No time entries logged for the selected period.</div>';
      return;
    }
    entries = appData.timeEntries.filter(e => e.spent_date >= timeRange.from && e.spent_date <= timeRange.to);
  }
  
  if (timeRange.error) {
    cards.innerHTML = '';
    byClient.innerHTML = `<div style="padding: 40px; text-align: center; color: var(--gray-mid);">Could not load data for this date range. Please try again.</div>`;
    return;
  }
  
  const rangeLabel = formatRangeLabel(timeRange.from, timeRange.to);
  
  // Billable totals
  const billableEntries = entries.filter(e => e.billable);
  const totalBillable = billableEntries.reduce((s, e) => s + (parseFloat(e.hours) || 0), 0);
  
  // Active DBAs in range (unique users with billable entries)
  const activeDBAsSet = new Set();
  billableEntries.forEach(e => { if (e.user && e.user.name) activeDBAsSet.add(e.user.name); });
  
  // Days in range (for context)
  const fromDt = new Date(timeRange.from + 'T00:00:00');
  const toDt = new Date(timeRange.to + 'T00:00:00');
  const daysInRange = Math.floor((toDt - fromDt) / (1000*60*60*24)) + 1;
  
  cards.innerHTML = `
    <div class="time-card">
      <div class="label">Billable Hours</div>
      <div class="value">${formatHours(totalBillable)}</div>
      <div class="unit">${rangeLabel}</div>
    </div>
    <div class="time-card">
      <div class="label">Active DBAs</div>
      <div class="value">${activeDBAsSet.size}</div>
      <div class="unit">logged billable hours</div>
    </div>
    <div class="time-card">
      <div class="label">Avg / Day</div>
      <div class="value">${formatHours(totalBillable / daysInRange)}</div>
      <div class="unit">billable hrs / day in range</div>
    </div>
    <div class="time-card">
      <div class="label">Billable Entries</div>
      <div class="value">${billableEntries.length}</div>
      <div class="unit">records in range</div>
    </div>
  `;
  
  // Hours per DBA in selected range
  byClient.innerHTML = '';
  const dbaTotals = {};
  billableEntries.forEach(e => {
    const n = e.user && e.user.name ? e.user.name : 'Unknown';
    dbaTotals[n] = (dbaTotals[n] || 0) + (parseFloat(e.hours) || 0);
  });
  const sortedDBAs = Object.entries(dbaTotals).sort(([,a],[,b]) => b - a);
  
  const dbaSection = document.createElement('div');
  dbaSection.style.marginBottom = '24px';
  dbaSection.innerHTML = `
    <div style="font-size: 0.75rem; color: var(--gray-mid); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px;">Billable hours per DBA – ${rangeLabel}</div>
  `;
  
  if (sortedDBAs.length === 0) {
    dbaSection.innerHTML += '<div style="color: var(--gray-mid); padding: 12px;">No billable DBA hours in this range.</div>';
  } else {
    const maxDba = sortedDBAs[0][1] || 1;
    sortedDBAs.forEach(([name, hours], i) => {
      dbaSection.innerHTML += `
        <div class="bar-row">
          <div class="bar-rank">${i + 1}</div>
          <div class="bar-info">
            <div class="bar-name">${escapeHtml(name)}</div>
            <div class="bar-track"><div class="bar-fill" style="width: ${maxDba ? (hours/maxDba*100).toFixed(0) : 0}%"></div></div>
          </div>
          <div class="bar-value">${formatHours(hours)}h</div>
        </div>
      `;
    });
  }
  byClient.appendChild(dbaSection);
  
  // Hours by client in selected range
  const clientTotals = {};
  billableEntries.forEach(e => {
    const name = (e.client && e.client.name) || (e.project && e.project.name) || 'Unknown';
    clientTotals[name] = (clientTotals[name] || 0) + (parseFloat(e.hours) || 0);
  });
  const sorted = Object.entries(clientTotals).sort(([,a],[,b]) => b - a);
  const max = sorted.length ? sorted[0][1] : 1;
  
  const clientSection = document.createElement('div');
  clientSection.innerHTML = `
    <div style="font-size: 0.75rem; color: var(--gray-mid); margin-bottom: 12px; margin-top: 16px; text-transform: uppercase; letter-spacing: 0.5px; padding-top: 16px; border-top: 1px solid var(--gray-border);">Billable hours by client – ${rangeLabel}</div>
  `;
  
  if (sorted.length === 0) {
    clientSection.innerHTML += '<div style="color: var(--gray-mid); padding: 12px;">No billable client time entries in this range.</div>';
  } else {
    sorted.slice(0, 12).forEach(([name, hours], i) => {
      clientSection.innerHTML += `
        <div class="bar-row">
          <div class="bar-rank">${i + 1}</div>
          <div class="bar-info">
            <div class="bar-name">${escapeHtml(name)}</div>
            <div class="bar-track"><div class="bar-fill" style="width: ${(hours/max*100).toFixed(0)}%"></div></div>
          </div>
          <div class="bar-value">${formatHours(hours)}h</div>
        </div>
      `;
    });
  }
  byClient.appendChild(clientSection);
}

