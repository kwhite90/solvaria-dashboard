// CONSULTANT CAPACITY ASSESSMENT MODAL
// (mirrors CSM dashboard's openConsultantAssessment - fetches last 6 months from Harvest)
// ============================================================================
async function openConsultantAssessment(name) {
  const overlay = document.getElementById('assessment-modal-overlay');
  document.getElementById('assessment-name').textContent = name;
  document.getElementById('assessment-loading').style.display = 'block';
  document.getElementById('assessment-content').style.display = 'none';
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
  
  if (!appData.harvestConfig || !appData.harvestConfig.token || !appData.harvestConfig.accountId) {
    document.getElementById('assessment-loading').textContent = 'Live data is not currently available.';
    return;
  }
  
  const headers = {
    'Authorization': `Bearer ${appData.harvestConfig.token}`,
    'Harvest-Account-Id': appData.harvestConfig.accountId,
    'User-Agent': 'Solvaria Executive Dashboard'
  };
  
  try {
    // Fetch last 6 months of data, one month at a time
    const today = new Date();
    const monthlyData = [];
    
    for (let i = 5; i >= 0; i--) {
      const monthDate = new Date(today.getFullYear(), today.getMonth() - i, 1);
      const year = monthDate.getFullYear();
      const month = monthDate.getMonth() + 1;
      const fromDate = `${year}-${String(month).padStart(2, '0')}-01`;
      const lastDay = new Date(year, month, 0).getDate();
      const toDate = `${year}-${String(month).padStart(2, '0')}-${String(lastDay).padStart(2, '0')}`;
      
      // Paginate through all entries for the month
      let totalHours = 0;
      let page = 1;
      let hasMore = true;
      while (hasMore) {
        const url = `https://api.harvestapp.com/v2/time_entries?from=${fromDate}&to=${toDate}&page=${page}&per_page=2000`;
        const resp = await fetch(url, { headers });
        if (!resp.ok) throw new Error('Could not load monthly data');
        const data = await resp.json();
        (data.time_entries || []).forEach(entry => {
          if (entry.billable && entry.user && entry.user.name === name) {
            totalHours += entry.hours;
          }
        });
        const totalPages = data.total_pages || 1;
        hasMore = page < totalPages;
        page++;
      }
      
      monthlyData.push({
        month: monthDate.toLocaleDateString('en-US', { month: 'short', year: '2-digit' }),
        hours: totalHours
      });
    }
    
    const capacity = 160; // monthly target
    const avgHours = monthlyData.reduce((s, m) => s + m.hours, 0) / monthlyData.length;
    const avgUtil = (avgHours / capacity * 100);
    
    renderConsultantAssessment(name, capacity, monthlyData, avgHours, avgUtil);
  } catch (err) {
    console.error('Assessment fetch error:', err);
    document.getElementById('assessment-loading').textContent = 'Data is temporarily unavailable. Please try again.';
  }
}

function renderConsultantAssessment(name, capacity, monthlyData, avgHours, avgUtil) {
  document.getElementById('assessment-loading').style.display = 'none';
  document.getElementById('assessment-content').style.display = 'block';
  
  // Metrics
  document.getElementById('assessment-capacity').textContent = `${capacity}h`;
  document.getElementById('assessment-avg-hours').textContent = `${formatHours(avgHours)}h`;
  const utilEl = document.getElementById('assessment-avg-util');
  utilEl.textContent = `${avgUtil.toFixed(0)}%`;
  if (avgUtil >= 100) utilEl.style.color = 'var(--red)';
  else if (avgUtil >= 85) utilEl.style.color = '#8a5a00';
  else utilEl.style.color = 'var(--green)';
  
  // Chart
  const maxHours = Math.max(...monthlyData.map(m => m.hours), capacity);
  const chartHtml = monthlyData.map(m => {
    const pct = (m.hours / maxHours * 100);
    const utilPct = (m.hours / capacity * 100);
    const cls = utilPct > 100 ? 'over' : utilPct > 85 ? 'high' : '';
    return `
      <div class="assessment-chart-row">
        <div class="assessment-chart-month">${m.month}</div>
        <div class="assessment-chart-bar-track">
          <div class="assessment-chart-bar-fill ${cls}" style="width: ${pct}%"></div>
        </div>
        <div class="assessment-chart-hours">${formatHours(m.hours)}h</div>
      </div>
    `;
  }).join('');
  document.getElementById('assessment-chart-rows').innerHTML = chartHtml;
  
  // Recommendation (recent 3 months) - same thresholds as CSM, softer language
  const recentMonths = monthlyData.slice(-3);
  const recentAvg = recentMonths.reduce((s, m) => s + m.hours, 0) / 3;
  const recentUtil = (recentAvg / capacity * 100);
  
  let status, statusColor, statusBg, statusBorder, icon, recommendation;
  
  if (recentUtil >= 95) {
    status = 'Fully Allocated';
    icon = '🔴';
    statusBg = '#fdecea';
    statusColor = '#C62828';
    statusBorder = '#f5b5b0';
    recommendation = `${escapeHtml(name)} is consistently fully allocated at <strong>${recentUtil.toFixed(0)}%</strong> over the last 3 months. Adding new client work right now would risk over-allocation and could affect quality on existing engagements. <strong>Best action:</strong> hold off on assigning new projects until current load decreases.`;
  } else if (recentUtil >= 80) {
    status = 'Limited Availability';
    icon = '🟡';
    statusBg = '#fff4dc';
    statusColor = '#8a5a00';
    statusBorder = '#f5d989';
    recommendation = `${escapeHtml(name)} is operating at <strong>${recentUtil.toFixed(0)}%</strong> over the last 3 months. There is limited bandwidth for additional work. <strong>Best action:</strong> consider only small, low-urgency assignments (≤8 hrs/month) and avoid high-priority or time-sensitive work.`;
  } else {
    const availableHours = capacity - recentAvg;
    status = 'Available for New Work';
    icon = '🟢';
    statusBg = '#e8f5e9';
    statusColor = '#2E7D32';
    statusBorder = '#a5d6a7';
    recommendation = `${escapeHtml(name)} has bandwidth available (<strong>${recentUtil.toFixed(0)}%</strong> average utilization). Approximately <strong>${formatHours(availableHours)} hours per month</strong> are open for new project work. <strong>Best action:</strong> well-suited to take on additional client engagements.`;
  }
  
  const statusEl = document.getElementById('assessment-status');
  statusEl.innerHTML = `<span>${icon}</span><span>${status}</span>`;
  statusEl.style.background = statusBg;
  statusEl.style.color = statusColor;
  statusEl.style.borderColor = statusBorder;
  
  document.getElementById('assessment-recommendation').innerHTML = recommendation;
}

function closeConsultantAssessment() {
  document.getElementById('assessment-modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

// Escape key closes modal
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeConsultantAssessment();
});

// ============================================================================
// INIT
// ============================================================================
function renderAll() {
  renderOverview();
  renderClients();
  renderTime();
  renderCapacity();
}

document.addEventListener('DOMContentLoaded', async () => {
  // Show initial loading state
  initDBAUI();
  renderAll();
  
  // Load data (async, fetches Harvest API)
  await loadData();
  renderAll();
});
</script>

