<script>
// ============================================================================
// DATA LOADER: Reads from CSM localStorage + fetches live Harvest API
// ============================================================================
let appData = { 
  clients: {}, 
  harvestConfig: null,
  timeEntries: [],
  projects: [],
  weeklyReports: {},
  // Computed
  hoursMap: {},
  capacityMatrix: {},
  capacityClients: [],
  clientOwners: {},
  projectBudgets: {},
  // Date range tracking
  weekFrom: '', weekTo: '',
  monthFrom: '', monthTo: '',
  // Status
  loading: false,
  lastError: null
};

// Date helpers (same logic as CSM dashboard)
// Format a Date object as YYYY-MM-DD using LOCAL time components
// (avoids the toISOString UTC shift that can move dates by a day)
function formatLocalDate(d) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}

function getCurrentWeekDates() {
  const today = new Date();
  const dayOfWeek = today.getDay();
  // Build monday using local-time components only (avoids DST/timezone edge cases)
  const offset = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
  const monday = new Date(today.getFullYear(), today.getMonth(), today.getDate() + offset);
  const sunday = new Date(monday.getFullYear(), monday.getMonth(), monday.getDate() + 6);
  return {
    fromDate: formatLocalDate(monday),
    toDate: formatLocalDate(sunday)
  };
}

function getCurrentMonthDates() {
  const today = new Date();
  const y = today.getFullYear();
  const m = today.getMonth();
  const fromDate = `${y}-${String(m+1).padStart(2,'0')}-01`;
  const lastDay = new Date(y, m+1, 0).getDate();
  const toDate = `${y}-${String(m+1).padStart(2,'0')}-${String(lastDay).padStart(2,'0')}`;
  return { fromDate, toDate };
}

function loadData() {
  // Read clients from CSM localStorage, fetch fresh data from Harvest API
  try {
    const dashRaw = localStorage.getItem('solvaria-dashboard-data');
    if (dashRaw) {
      const dash = JSON.parse(dashRaw);
      appData.clients = dash.clients || {};
    }
  } catch(e) { console.warn('Could not load dashboard data', e); }
  
  try {
    const harvRaw = localStorage.getItem('harvest-config');
    if (harvRaw) appData.harvestConfig = JSON.parse(harvRaw);
  } catch(e) {}
  
  try {
    const wrRaw = localStorage.getItem('solvaria-weekly-reports');
    if (wrRaw) appData.weeklyReports = JSON.parse(wrRaw);
  } catch(e) {}
  
  // If Harvest credentials are present, fetch live data
  if (appData.harvestConfig && appData.harvestConfig.token && appData.harvestConfig.accountId) {
    return fetchHarvestData();
  }
  
  updateLastSync();
  return Promise.resolve();
}

async function fetchHarvestData() {
  if (!appData.harvestConfig || !appData.harvestConfig.token || !appData.harvestConfig.accountId) {
    return;
  }
  
  appData.loading = true;
  appData.lastError = null;
  updateLastSync();
  
  const headers = {
    'Authorization': `Bearer ${appData.harvestConfig.token}`,
    'Harvest-Account-Id': appData.harvestConfig.accountId,
    'User-Agent': 'Solvaria Executive Dashboard'
  };
  
  try {
    // Fetch active projects (for budgets)
    console.log('📊 [Exec] Fetching projects...');
    const projectsResp = await fetch('https://api.harvestapp.com/v2/projects?is_active=true', { headers });
    if (!projectsResp.ok) throw new Error(`Projects fetch failed (${projectsResp.status})`);
    const projectsData = await projectsResp.json();
    appData.projects = projectsData.projects || [];
    
    // Build project budget map (same as CSM dashboard's loadCapacityData)
    appData.projectBudgets = {};
    appData.projects.forEach(p => {
      if (p.budget && p.budget > 0) {
        appData.projectBudgets[p.name] = { hours: p.budget, recurring: true };
      }
    });
    
    // Fetch time entries: pull current MONTH (covers both week and month views)
    const monthDates = getCurrentMonthDates();
    appData.monthFrom = monthDates.fromDate;
    appData.monthTo = monthDates.toDate;
    
    const weekDates = getCurrentWeekDates();
    appData.weekFrom = weekDates.fromDate;
    appData.weekTo = weekDates.toDate;
    
    console.log(`📊 [Exec] Fetching time entries ${appData.monthFrom} to ${appData.monthTo}...`);
    let allEntries = [];
    let page = 1;
    let hasMore = true;
    while (hasMore) {
      const url = `https://api.harvestapp.com/v2/time_entries?from=${appData.monthFrom}&to=${appData.monthTo}&page=${page}&per_page=2000`;
      const resp = await fetch(url, { headers });
      if (!resp.ok) throw new Error(`Time entries fetch failed (${resp.status})`);
      const data = await resp.json();
      allEntries = allEntries.concat(data.time_entries || []);
      const totalPages = data.total_pages || 1;
      hasMore = page < totalPages;
      page++;
    }
    appData.timeEntries = allEntries;
    console.log(`✅ [Exec] Total entries fetched: ${allEntries.length}`);
    
    // Process: hours per DBA (week), capacity matrix (month) - mirror CSM logic
    processHarvestData();
    
    appData.loading = false;
    appData.lastError = null;
    updateLastSync();
  } catch (err) {
    console.error('[Exec] Harvest fetch error:', err);
    appData.loading = false;
    appData.lastError = err.message;
    updateLastSync();
  }
}

function processHarvestData() {
  // === Compute hoursMap by DBA for current WEEK (billable only) - same as CSM ===
  const weekFrom = new Date(appData.weekFrom + 'T00:00:00');
  const weekTo = new Date(appData.weekTo + 'T23:59:59');
  
  const trackedDBAs = (appData.harvestConfig.dbas || []);
  const hoursMap = {};
  trackedDBAs.forEach(d => { hoursMap[d] = 0; });
  
  const weekEntries = appData.timeEntries.filter(e => {
    const d = new Date(e.spent_date + 'T12:00:00');
    return d >= weekFrom && d <= weekTo;
  });
  
  weekEntries.forEach(entry => {
    if (!entry.billable) return;
    const userName = entry.user.name;
    trackedDBAs.forEach(dba => {
      if (userName.toLowerCase().includes(dba.toLowerCase()) || 
          dba.toLowerCase().includes(userName.toLowerCase())) {
        hoursMap[dba] = (hoursMap[dba] || 0) + entry.hours;
      }
    });
  });
  appData.hoursMap = hoursMap;
  
  // === Compute capacity matrix for current MONTH (billable only) - same as CSM ===
  const matrix = {};
  const clientSet = new Set();
  const clientOwners = {};
  
  appData.timeEntries.forEach(entry => {
    if (!entry.billable) return;
    const consultant = entry.user.name;
    const projectName = entry.project.name;
    
    clientSet.add(projectName);
    
    if (!clientOwners[projectName]) {
      const dbClient = Object.values(appData.clients).find(c => 
        projectName.toLowerCase().includes((c.name || '').toLowerCase()) || 
        (c.name || '').toLowerCase().includes(projectName.toLowerCase())
      );
      clientOwners[projectName] = dbClient ? (dbClient.owner || 'Unknown') : 'Unknown';
    }
    
    if (!matrix[consultant]) matrix[consultant] = {};
    if (!matrix[consultant][projectName]) matrix[consultant][projectName] = 0;
    matrix[consultant][projectName] += entry.hours;
  });
  
  appData.capacityMatrix = matrix;
  appData.capacityClients = Array.from(clientSet).sort();
  appData.clientOwners = clientOwners;
}

function updateLastSync() {
  const el = document.getElementById('last-sync');
  if (!el) return;
  if (appData.loading) {
    el.textContent = 'Loading latest data...';
    el.style.color = 'rgba(255,255,255,0.6)';
    return;
  }
  if (appData.lastError) {
    el.textContent = 'Unable to load latest data';
    el.style.color = 'rgba(255,255,255,0.6)';
    return;
  }
  if (!appData.harvestConfig || !appData.harvestConfig.token) {
    el.textContent = '';
    el.style.color = 'rgba(255,255,255,0.6)';
    return;
  }
  el.textContent = `Updated ${new Date().toLocaleString('en-US', { hour: 'numeric', minute: '2-digit' })}`;
  el.style.color = 'rgba(255,255,255,0.6)';
}

async function refreshData() {
  await loadData();
  renderAll();
}

