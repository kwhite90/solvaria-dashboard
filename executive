<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solvaria | Company at a Glance</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">



<style>
:root {
  --navy: #1B2040;
  --navy-light: #252c50;
  --navy-mid: #3a4570;
  --cyan: #3EC9E0;
  --cyan-soft: rgba(62, 201, 224, 0.12);
  --cyan-dim: #2ba3b8;
  --green: #2E7D32;
  --green-soft: #e8f5e9;
  --red: #D32F2F;
  --amber: #F5A623;
  --amber-soft: #fffbf0;
  --purple: #8B72E8;
  --gray-light: #f5f7fa;
  --gray-border: #e1e6ed;
  --gray-mid: #8a93b0;
  --gray-text: #6b7785;
  --shadow-sm: 0 1px 2px rgba(27,32,64,0.06);
  --shadow-md: 0 2px 8px rgba(27,32,64,0.08);
  --shadow-lg: 0 4px 16px rgba(27,32,64,0.12);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Barlow', sans-serif;
  background: var(--gray-light);
  color: var(--navy);
  line-height: 1.5;
  min-height: 100vh;
}

/* ===== HEADER ===== */
header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
  color: white;
  padding: 24px 36px;
  box-shadow: var(--shadow-md);
}
.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}
.header-left { display: flex; align-items: center; gap: 24px; }
.brand-mark {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 2.2rem;
  color: white;
  letter-spacing: 0.05em;
  line-height: 1;
}
.brand-mark .accent { color: var(--cyan); }
.header-title {
  border-left: 2px solid rgba(255,255,255,0.2);
  padding-left: 24px;
}
.header-title .eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--cyan);
  margin-bottom: 4px;
}
.header-title h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.6rem;
  letter-spacing: 0.5px;
}
.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.header-btn {
  background: rgba(255,255,255,0.08);
  color: white;
  border: 1px solid rgba(255,255,255,0.2);
  padding: 8px 16px;
  border-radius: 4px;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 600;
  font-size: 0.85rem;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s;
}
.header-btn:hover {
  background: rgba(255,255,255,0.15);
  border-color: var(--cyan);
}

/* ===== TABS ===== */
.tabs-bar {
  background: white;
  padding: 0 36px;
  border-bottom: 1px solid var(--gray-border);
  display: flex;
  gap: 0;
  overflow-x: auto;
  box-shadow: var(--shadow-sm);
}
.tab-btn {
  background: transparent;
  border: none;
  padding: 18px 22px;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 600;
  font-size: 0.95rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--gray-text);
  cursor: pointer;
  border-bottom: 3px solid transparent;
  transition: all 0.2s;
  white-space: nowrap;
  position: relative;
  top: 1px;
}
.tab-btn:hover { color: var(--navy); }
.tab-btn.active {
  color: var(--navy);
  border-bottom-color: var(--cyan);
}

/* ===== MAIN ===== */
main { padding: 28px 36px; max-width: 1600px; margin: 0 auto; }
.tab-panel { display: none; }
.tab-panel.active { display: block; }

.section-header {
  margin-bottom: 24px;
}
.section-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.4rem;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: var(--navy);
  margin-bottom: 6px;
}
.section-sub {
  color: var(--gray-text);
  font-size: 0.9rem;
}

/* ===== OVERVIEW KPI CARDS ===== */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
  margin-bottom: 28px;
}
.kpi-card {
  background: white;
  border-radius: 8px;
  padding: 22px 24px;
  box-shadow: var(--shadow-md);
  border-top: 4px solid var(--cyan);
  position: relative;
  overflow: hidden;
}
.kpi-card.clickable {
  cursor: pointer;
  transition: all 0.2s;
}
.kpi-card.clickable:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}
.kpi-card.clickable:hover .kpi-cta {
  color: var(--cyan);
  transform: translateX(2px);
}
.kpi-card.clickable:focus {
  outline: 2px solid var(--cyan);
  outline-offset: 2px;
}
.kpi-cta {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--gray-mid);
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--gray-border);
  transition: all 0.2s;
}
.kpi-card.green { border-top-color: var(--green); }
.kpi-card.amber { border-top-color: var(--amber); }
.kpi-card.purple { border-top-color: var(--purple); }
.kpi-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gray-text);
  margin-bottom: 8px;
}
.kpi-value {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.6rem;
  font-weight: 800;
  color: var(--navy);
  line-height: 1;
  letter-spacing: -0.5px;
}
.kpi-suffix {
  font-size: 1rem;
  color: var(--gray-mid);
  font-weight: 500;
  margin-left: 4px;
}
.kpi-meta {
  font-size: 0.8rem;
  color: var(--gray-mid);
  margin-top: 6px;
}

/* ===== OVERVIEW PANELS ===== */
.overview-row {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 20px;
  margin-bottom: 24px;
}
@media (max-width: 1000px) {
  .overview-row { grid-template-columns: 1fr; }
}
.panel {
  background: white;
  border-radius: 8px;
  padding: 24px 26px;
  box-shadow: var(--shadow-md);
}
.panel-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.05rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--navy);
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--gray-border);
  display: flex;
  align-items: center;
  gap: 8px;
}
.panel-title .accent-bar {
  display: inline-block;
  width: 4px;
  height: 18px;
  background: var(--cyan);
  border-radius: 2px;
}

/* Top clients bar list */
.bar-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--gray-border); }
.bar-row:last-child { border-bottom: none; }
.bar-rank {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  color: var(--cyan);
  background: var(--cyan-soft);
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.bar-info { flex: 1; min-width: 0; }
.bar-name { font-weight: 600; color: var(--navy); font-size: 0.92rem; }
.bar-track { background: var(--gray-light); height: 6px; border-radius: 3px; margin-top: 4px; overflow: hidden; }
.bar-fill { background: var(--cyan); height: 100%; border-radius: 3px; transition: width 0.4s; }
.bar-value { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; color: var(--navy); font-size: 0.95rem; min-width: 60px; text-align: right; }

/* Tier breakdown */
.tier-breakdown { display: flex; flex-direction: column; gap: 12px; }
.tier-card {
  padding: 14px 16px;
  border-radius: 6px;
  border: 1px solid var(--gray-border);
  border-left: 4px solid var(--cyan);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.tier-card.bronze { border-left-color: #b88142; background: linear-gradient(90deg, rgba(184,129,66,0.05), transparent); }
.tier-card.silver { border-left-color: #8aab2d; background: linear-gradient(90deg, rgba(138,171,45,0.05), transparent); }
.tier-card.gold { border-left-color: var(--navy); background: linear-gradient(90deg, rgba(27,32,64,0.05), transparent); }
.tier-card.other { border-left-color: var(--gray-mid); }
.tier-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.8px; }
.tier-count { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--navy); }

/* Industries chips */
.chip-row { display: flex; flex-wrap: wrap; gap: 8px; }
.industry-chip {
  background: var(--cyan-soft);
  color: var(--navy);
  padding: 6px 12px;
  border-radius: 14px;
  font-size: 0.85rem;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.industry-chip .count {
  background: var(--cyan);
  color: white;
  font-weight: 700;
  font-size: 0.72rem;
  padding: 1px 7px;
  border-radius: 8px;
}

/* ===== CLIENT METRICS ===== */
.client-toolbar {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
  align-items: center;
  flex-wrap: wrap;
}
.client-search {
  flex: 1;
  min-width: 240px;
  padding: 10px 14px;
  border: 1px solid var(--gray-border);
  border-radius: 4px;
  font-size: 0.9rem;
  font-family: 'Barlow', sans-serif;
}
.client-search:focus {
  outline: none;
  border-color: var(--cyan);
  box-shadow: 0 0 0 3px var(--cyan-soft);
}
.client-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.client-table thead th.num { text-align: right; }
.client-table tbody td.num { text-align: right; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.95rem; }
.client-table thead th {
  background: var(--navy);
  color: white;
  padding: 12px 14px;
  text-align: left;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  font-size: 0.78rem;
  white-space: nowrap;
}
.client-table tbody td {
  padding: 12px 14px;
  border-bottom: 1px solid var(--gray-border);
  font-size: 0.9rem;
  color: var(--navy);
}
.client-table tbody tr:hover td { background: #f8fafc; }
.client-table tbody tr:last-child td { border-bottom: none; }
.status-badge {
  display: inline-block;
  padding: 3px 9px;
  border-radius: 3px;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-family: 'Barlow Condensed', sans-serif;
}
.status-badge.critical { background: #fdecea; color: var(--red); }
.status-badge.important { background: #fff4dc; color: #8a5a00; }
.status-badge.normal { background: #e8f5e9; color: var(--green); }
.status-badge.unknown { background: var(--gray-light); color: var(--gray-text); }

.health-badge {
  display: inline-block;
  padding: 4px 11px;
  border-radius: 12px;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-family: 'Barlow Condensed', sans-serif;
}
.health-badge.on-track { background: var(--green-soft); color: var(--green); }
.health-badge.at-risk { background: #fff4dc; color: #8a5a00; }
.health-badge.over { background: #fdecea; color: var(--red); }
.health-badge.untracked { background: var(--gray-light); color: var(--gray-text); }

.dba-list {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}
.dba-tag {
  background: var(--cyan-soft);
  color: var(--navy);
  padding: 2px 8px;
  border-radius: 3px;
  font-size: 0.75rem;
  font-weight: 500;
}

/* ===== EMPTY STATES ===== */
.empty-state {
  background: white;
  padding: 60px 20px;
  text-align: center;
  color: var(--gray-text);
  border-radius: 8px;
  box-shadow: var(--shadow-sm);
}
.empty-state h3 {
  color: var(--navy);
  font-family: 'Barlow Condensed', sans-serif;
  margin-bottom: 8px;
  font-size: 1.2rem;
}

/* ===== TIME TRACKING ===== */
.time-filter-bar {
  background: white;
  padding: 16px 20px;
  border-radius: 8px;
  box-shadow: var(--shadow-md);
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}
.time-filter-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--gray-text);
}
.time-filter-chips {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}
.time-chip {
  background: white;
  border: 1px solid var(--gray-border);
  color: var(--navy);
  padding: 6px 14px;
  border-radius: 16px;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Barlow', sans-serif;
  transition: all 0.15s;
}
.time-chip:hover {
  border-color: var(--cyan);
  color: var(--cyan-dim);
}
.time-chip.active {
  background: var(--navy);
  color: white;
  border-color: var(--navy);
}
.time-chip.apply {
  background: var(--cyan);
  color: var(--navy);
  border-color: var(--cyan);
  font-weight: 700;
}
.time-chip.apply:hover { background: #5dd4e8; }
.time-filter-custom {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  margin-top: 8px;
  padding-top: 12px;
  border-top: 1px solid var(--gray-border);
  flex-wrap: wrap;
}
.time-filter-custom label {
  font-size: 0.85rem;
  color: var(--gray-text);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 6px;
}
.time-filter-custom input[type="date"] {
  padding: 6px 10px;
  border: 1px solid var(--gray-border);
  border-radius: 4px;
  font-family: 'Barlow', sans-serif;
  font-size: 0.85rem;
  color: var(--navy);
}
.time-filter-custom input[type="date"]:focus {
  outline: none;
  border-color: var(--cyan);
}

.time-summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}
.time-card {
  background: white;
  padding: 20px;
  border-radius: 8px;
  box-shadow: var(--shadow-md);
  text-align: center;
}
.time-card .label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gray-text);
  margin-bottom: 6px;
}
.time-card .value {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--navy);
  line-height: 1;
}
.time-card .unit {
  font-size: 0.9rem;
  color: var(--gray-mid);
  margin-top: 6px;
}

/* ===== CAPACITY PLANNING ===== */
.capacity-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.capacity-table thead th {
  background: var(--navy);
  color: white;
  padding: 12px 14px;
  text-align: left;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  font-size: 0.78rem;
}
.capacity-table thead th.num { text-align: right; }
.capacity-table tbody td {
  padding: 11px 14px;
  border-bottom: 1px solid var(--gray-border);
  font-size: 0.9rem;
}
.capacity-table tbody td.num { text-align: right; font-family: 'Barlow Condensed', sans-serif; font-weight: 600; }
.utilization-bar {
  display: inline-block;
  width: 100%;
  max-width: 160px;
  height: 8px;
  background: var(--gray-light);
  border-radius: 4px;
  overflow: hidden;
  vertical-align: middle;
  margin-right: 8px;
}
.utilization-fill {
  height: 100%;
  background: var(--cyan);
  border-radius: 4px;
}
.utilization-fill.high { background: var(--amber); }
.utilization-fill.over { background: var(--red); }

/* ===== TEAM & SERVICES ===== */
/* Reuse SM- prefixed classes from main dashboard skills matrix */
.sub-section { margin-bottom: 40px; }
.sub-section:last-child { margin-bottom: 0; }
.sub-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.15rem;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: var(--navy);
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--cyan);
}
.service-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 18px;
}
.service-card {
  background: white;
  border: 1px solid var(--gray-border);
  border-left: 4px solid var(--cyan);
  border-radius: 6px;
  padding: 20px 22px;
  box-shadow: var(--shadow-sm);
}
.service-card h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.05rem;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--navy);
  margin-bottom: 12px;
}
.service-card ul { list-style: none; }
.service-card li {
  padding: 4px 0; padding-left: 16px; position: relative;
  font-size: 0.88rem; color: var(--gray-text);
}
.service-card li::before {
  content: ""; position: absolute; left: 0; top: 12px;
  width: 6px; height: 6px; background: var(--cyan); border-radius: 50%;
}

.tier-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 18px;
}
.mmt-tier {
  background: white;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-border);
}
.mmt-tier-header { padding: 16px 20px; color: white; text-align: center; }
.mmt-tier-header.bronze { background: linear-gradient(135deg, #b88142, #a16d35); }
.mmt-tier-header.silver { background: linear-gradient(135deg, #8aab2d, #6f8a23); }
.mmt-tier-header.gold { background: linear-gradient(135deg, var(--navy), var(--navy-light)); }
.mmt-tier-header h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1.3rem;
  letter-spacing: 1px;
  text-transform: uppercase;
}
.mmt-tier-price { padding: 16px 20px; background: #f8fafc; text-align: center; border-bottom: 1px solid var(--gray-border); }
.mmt-tier-price .amount { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.9rem; color: var(--navy); }
.mmt-tier-price .label { font-size: 0.7rem; color: var(--gray-text); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }
.mmt-tier-price .hours { font-size: 0.8rem; color: var(--navy); font-weight: 600; margin-top: 4px; }
.mmt-tier-body { padding: 16px 20px; }
.mmt-tier-body ul { list-style: none; font-size: 0.85rem; }
.mmt-tier-body li { padding: 4px 0; padding-left: 22px; position: relative; color: var(--navy); }
.mmt-tier-body li::before {
  content: "✓"; position: absolute; left: 0; top: 4px; color: var(--cyan); font-weight: 700;
}

.tech-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 14px;
}
.tech-card {
  background: var(--gray-light);
  border: 1px solid var(--gray-border);
  border-radius: 6px;
  padding: 16px 18px;
}
.tech-card h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--navy);
  margin-bottom: 8px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--cyan);
}
.tech-card ul { list-style: none; }
.tech-card li { font-size: 0.82rem; padding: 2px 0; color: var(--navy); }

.stats-bar {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 14px;
  background: var(--navy);
  padding: 22px;
