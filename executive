  const activeCompanies = new Set();
  Object.values(appData.clients || {}).forEach(c => {
    if (c.name === 'GEM' || c.name === 'GEM (Internal)') return;
    if (c.status === 'completed' || c.status === 'closed') return;
    if (!c.clientName || c.clientName === c.name) return;
    activeCompanies.add(c.clientName);
  });
  const activeClientCount = activeCompanies.size;
  
  // Total active projects/engagements (still useful as a metric)
  const activeProjects = Object.values(appData.clients || {}).filter(c => {
    if (c.name === 'GEM' || c.name === 'GEM (Internal)') return false;
    if (c.status === 'completed' || c.status === 'closed') return false;
    return true;
  });
  
  // Billable hours only (executive view filters out non-billable per Solvaria preference)
  // Use string comparison on spent_date (YYYY-MM-DD) to avoid timezone shifts
  let weekHours = 0;
  
  if (appData.timeEntries && appData.timeEntries.length && appData.weekFrom && appData.weekTo) {
    appData.timeEntries.forEach(e => {
      if (!e.billable) return;
      if (e.spent_date < appData.weekFrom || e.spent_date > appData.weekTo) return;
      weekHours += parseFloat(e.hours) || 0;
    });
  }
  
  // Team size from skills matrix
  const teamSize = dbaTeamData.length;
  
  // Build KPI cards (clickable - navigate to respective tabs)
  const kpis = [
    { label: 'Active Clients', value: activeClientCount, suffix: '', meta: `${activeProjects.length} active engagements`, color: '', tab: 'clients' },
    { label: 'Team Members', value: teamSize, suffix: '', meta: 'senior DBAs and consultants', color: 'green', tab: 'team' },
    { label: 'Hours This Week', value: formatHours(weekHours), suffix: 'hrs', meta: 'billable hours, all consultants', color: 'amber', tab: 'time' }
  ];
  
  document.getElementById('overview-kpis').innerHTML = kpis.map(k => `
    <div class="kpi-card ${k.color} clickable" onclick="switchTab('${k.tab}')" role="button" tabindex="0" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('${k.tab}')}">
      <div class="kpi-label">${k.label}</div>
      <div class="kpi-value">${k.value}${k.suffix ? `<span class="kpi-suffix">${k.suffix}</span>` : ''}</div>
      <div class="kpi-meta">${k.meta}</div>
      <div class="kpi-cta">View details →</div>
    </div>
  `).join('');
  
  // Top clients by hours (current month, billable only)
  const clientHours = {};
  if (appData.timeEntries && appData.timeEntries.length) {
    appData.timeEntries.forEach(e => {
      if (!e.billable) return;
      const name = (e.client && e.client.name) || (e.project && e.project.name) || 'Unknown';
      clientHours[name] = (clientHours[name] || 0) + (parseFloat(e.hours) || 0);
    });
  }
  const topClients = Object.entries(clientHours)
    .sort(([,a], [,b]) => b - a)
    .slice(0, 8);
  const maxHours = topClients.length ? topClients[0][1] : 1;
  
  const topClientsEl = document.getElementById('top-clients-list');
  if (topClients.length === 0) {
    if (appData.loading) {
      topClientsEl.innerHTML = '<div style="padding: 30px; text-align: center; color: var(--gray-mid); font-size: 0.9rem;">Loading...</div>';
    } else {
      topClientsEl.innerHTML = '<div style="padding: 30px; text-align: center; color: var(--gray-mid); font-size: 0.9rem;">Data currently unavailable</div>';
    }
  } else {
    topClientsEl.innerHTML = `
      <div style="font-size: 0.75rem; color: var(--gray-mid); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px;">Billable hours, current month (${appData.monthFrom} to ${appData.monthTo})</div>
      ${topClients.map(([name, hours], i) => `
        <div class="bar-row">
          <div class="bar-rank">${i + 1}</div>
          <div class="bar-info">
            <div class="bar-name">${escapeHtml(name)}</div>
            <div class="bar-track"><div class="bar-fill" style="width: ${(hours / maxHours * 100).toFixed(0)}%"></div></div>
          </div>
          <div class="bar-value">${formatHours(hours)}h</div>
        </div>
      `).join('')}
    `;
  }
  
  // Budget Health Summary - mirrors the Status column logic in Client Metrics
  // Calculate health bucket per company (deduplicated by clientName)
  const healthBuckets = { 'on-track': 0, 'at-risk': 0, 'over': 0, 'untracked': 0 };
  const seenCompanies = new Set();
  
  // Pre-aggregate project hours
  const _projectHoursOverview = {};
  if (appData.timeEntries) {
    appData.timeEntries.forEach(e => {
      if (!e.billable) return;
      const projName = (e.project && e.project.name) || '';
      if (!projName) return;
      _projectHoursOverview[projName] = (_projectHoursOverview[projName] || 0) + (parseFloat(e.hours) || 0);
    });
  }
  
  Object.values(appData.clients || {}).forEach(c => {
    // Same filtering as KPI: exclude internal and completed/closed
    if (c.name === 'GEM' || c.name === 'GEM (Internal)') return;
    if (c.status === 'completed' || c.status === 'closed') return;
    if (!c.clientName || c.clientName === c.name) return;
    if (seenCompanies.has(c.clientName)) return;
    seenCompanies.add(c.clientName);
    
    // Look up hours and budget (same logic as renderClients)
    let hours = _projectHoursOverview[c.name] || 0;
    let budget = 0;
    if (appData.projectBudgets && appData.projectBudgets[c.name]) {
      budget = appData.projectBudgets[c.name].hours || 0;
    }
    if (hours === 0) {
      Object.keys(_projectHoursOverview).forEach(projName => {
        if (projName.toLowerCase().includes(c.name.toLowerCase()) || 
            c.name.toLowerCase().includes(projName.toLowerCase())) {
          hours = Math.max(hours, _projectHoursOverview[projName]);
        }
      });
    }
    if (budget === 0 && appData.projectBudgets) {
      Object.keys(appData.projectBudgets).forEach(projName => {
        if (projName.toLowerCase().includes(c.name.toLowerCase()) || 
            c.name.toLowerCase().includes(projName.toLowerCase())) {
          budget = Math.max(budget, appData.projectBudgets[projName].hours || 0);
        }
      });
    }
    
    const utilization = budget > 0 ? (hours / budget * 100) : null;
    if (utilization === null) healthBuckets['untracked']++;
    else if (utilization > 100) healthBuckets['over']++;
    else if (utilization >= 85) healthBuckets['at-risk']++;
    else healthBuckets['on-track']++;
  });
  
  document.getElementById('status-breakdown').innerHTML = `
    <div class="tier-card" style="border-left-color: var(--green);">
      <div class="tier-name" style="color: var(--green);">On Track</div>
      <div class="tier-count">${healthBuckets['on-track']}</div>
    </div>
    <div class="tier-card" style="border-left-color: #8a5a00;">
      <div class="tier-name" style="color: #8a5a00;">Approaching Cap</div>
      <div class="tier-count">${healthBuckets['at-risk']}</div>
    </div>
    <div class="tier-card" style="border-left-color: var(--red);">
      <div class="tier-name" style="color: var(--red);">Over Allocation</div>
      <div class="tier-count">${healthBuckets['over']}</div>
    </div>
    ${healthBuckets['untracked'] > 0 ? `
    <div class="tier-card other">
      <div class="tier-name" style="color: var(--gray-mid);">No Allocation Set</div>
      <div class="tier-count">${healthBuckets['untracked']}</div>
    </div>` : ''}
    <div style="font-size: 0.75rem; color: var(--gray-mid); margin-top: 4px; line-height: 1.4;">Hours logged this month vs allocated hours per engagement. On Track &lt;85%, Approaching Cap 85-100%, Over Allocation &gt;100%.</div>
  `;
  
  // Industries from team data (aggregate)
  const industries = {};
  dbaTeamData.forEach(d => {
    (d.industries || []).forEach(i => {
      industries[i] = (industries[i] || 0) + 1;
    });
  });
  const topIndustries = Object.entries(industries).sort(([,a],[,b]) => b - a).slice(0, 15);
  document.getElementById('industries-chips').innerHTML = topIndustries.map(([name, count]) => `
    <span class="industry-chip">${escapeHtml(name)} <span class="count">${count}</span></span>
  `).join('');
  
  // Team snapshot
  const totalYears = dbaTeamData.reduce((s, d) => s + (d.yearsExp || 0), 0);
  const avgYears = (totalYears / dbaTeamData.length).toFixed(0);
  const totalCerts = dbaTeamData.reduce((s, d) => s + (d.certs || []).length, 0);
  const inProgressCerts = dbaTeamData.reduce((s, d) => s + (d.inProgressCerts || []).length, 0);
  
  document.getElementById('team-summary').innerHTML = `
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div>
        <div class="kpi-label">Total Experience</div>
        <div style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.8rem; color: var(--navy);">${totalYears}<span style="font-size: 0.9rem; color: var(--gray-mid); font-weight: 500;"> years combined</span></div>
      </div>
      <div>
        <div class="kpi-label">Avg per Consultant</div>
        <div style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.8rem; color: var(--navy);">${avgYears}<span style="font-size: 0.9rem; color: var(--gray-mid); font-weight: 500;"> years</span></div>
      </div>
      <div>
        <div class="kpi-label">Certifications Held</div>
        <div style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.8rem; color: var(--navy);">${totalCerts}</div>
      </div>
      <div>
        <div class="kpi-label">In Progress (Pilot)</div>
        <div style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1.8rem; color: var(--amber);">${inProgressCerts}</div>
      </div>
    </div>
  `;
}

