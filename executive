    wrap.innerHTML = '<div class="empty-state"><h3>Capacity data is temporarily unavailable</h3><p>Please try refreshing in a moment.</p></div>';
    return;
  }
  
  const matrix = appData.capacityMatrix || {};
  const projects = appData.capacityClients || [];
  const owners = appData.clientOwners || {};
  const budgets = appData.projectBudgets || {};
  
  // Filter out account managers and former consultants who shouldn't appear
  const EXCLUDED_FROM_CAPACITY = new Set(['Angel Smith', 'Pamela Craven', 'Jennifer Frayser', 'Karen Inman']);
  const consultants = Object.keys(matrix)
    .filter(c => !EXCLUDED_FROM_CAPACITY.has(c))
