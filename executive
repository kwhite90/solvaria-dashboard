function renderClients() {
  const search = (document.getElementById('client-search').value || '').toLowerCase();
  const statusFilter = document.getElementById('client-status-filter').value;
  
  let clients = Object.values(appData.clients || {})
    .filter(c => {
      // Same filtering as KPI: exclude internal and completed/closed
      if (c.name === 'GEM' || c.name === 'GEM (Internal)') return false;
      if (c.status === 'completed' || c.status === 'closed') return false;
      // Only show records that represent a proper company engagement
      if (!c.clientName || c.clientName === c.name) return false;
      return true;
    });
  
  if (statusFilter !== 'all') {
    clients = clients.filter(c => (c.status || 'unknown') === statusFilter);
  }
  
  // Compute hours billed per project from Harvest (current month)
  const projectHours = {};
  if (appData.timeEntries) {
    appData.timeEntries.forEach(e => {
      if (!e.billable) return;
      const projName = (e.project && e.project.name) || '';
      if (!projName) return;
      projectHours[projName] = (projectHours[projName] || 0) + (parseFloat(e.hours) || 0);
    });
  }
  
  // Build a map of who logged billable hours per project (fallback when explicit assignments missing)
  const projectContributors = {};
  if (appData.timeEntries) {
    appData.timeEntries.forEach(e => {
      if (!e.billable) return;
      if (!e.user || !e.user.name) return;
      const projName = (e.project && e.project.name) || '';
      if (!projName) return;
      // Skip account managers
      const userName = e.user.name;
      if (userName === 'Angel Smith' || userName === 'Pamela Craven') return;
      if (!projectContributors[projName]) projectContributors[projName] = new Set();
      projectContributors[projName].add(userName);
    });
  }
  
  // Look up hours, budget, and budget-status for each client
  const enriched = clients.map(c => {
    // Try exact match first, then loose match
    let hours = projectHours[c.name] || 0;
    let budget = 0;
    let matchedProjectName = c.name;
    if (appData.projectBudgets && appData.projectBudgets[c.name]) {
      budget = appData.projectBudgets[c.name].hours || 0;
    }
    // If no exact match, try loose match
    if (hours === 0) {
      Object.keys(projectHours).forEach(projName => {
        if (projName.toLowerCase().includes(c.name.toLowerCase()) || 
            c.name.toLowerCase().includes(projName.toLowerCase())) {
          if (projectHours[projName] > hours) {
            hours = projectHours[projName];
            matchedProjectName = projName;
          }
        }
      });
    }
    if (budget === 0 && appData.projectBudgets) {
      Object.keys(appData.projectBudgets).forEach(projName => {
        if (projName.toLowerCase().includes(c.name.toLowerCase()) || 
            c.name.toLowerCase().includes(projName.toLowerCase())) {
          budget = Math.max(budget, appData.projectBudgets[projName].hours || 0);
        }
      });
    }
    
    // Fallback: if client.assignments is empty, use anyone who logged billable hours
    let effectiveAssignments = (c.assignments && c.assignments.length) ? c.assignments.slice() : [];
    if (effectiveAssignments.length === 0) {
      // Try exact project match first
      const contributorsExact = projectContributors[c.name];
      if (contributorsExact && contributorsExact.size > 0) {
        effectiveAssignments = Array.from(contributorsExact);
      } else {
        // Loose match
        Object.keys(projectContributors).forEach(projName => {
          if (projName.toLowerCase().includes(c.name.toLowerCase()) || 
              c.name.toLowerCase().includes(projName.toLowerCase())) {
            projectContributors[projName].forEach(name => {
              if (!effectiveAssignments.includes(name)) effectiveAssignments.push(name);
            });
          }
        });
      }
    }
    
    const utilization = budget > 0 ? (hours / budget * 100) : null;
    
    let healthStatus = 'untracked';
    let healthLabel = 'No Allocation';
    if (utilization !== null) {
      if (utilization > 100) { healthStatus = 'over'; healthLabel = 'Over Allocation'; }
      else if (utilization >= 85) { healthStatus = 'at-risk'; healthLabel = 'Approaching Cap'; }
      else { healthStatus = 'on-track'; healthLabel = 'On Track'; }
    }
    
    return { ...c, _hours: hours, _budget: budget, _utilization: utilization, _healthStatus: healthStatus, _healthLabel: healthLabel, _effectiveAssignments: effectiveAssignments };
  });
  
  if (search) {
    const filtered = enriched.filter(c => {
      const blob = [
        c.name, c.clientName, c.owner,
        ...(c.assignments || [])
      ].filter(Boolean).join(' ').toLowerCase();
      return blob.includes(search);
    });
    enriched.length = 0;
    enriched.push(...filtered);
  }
  
  // Sort alphabetically by company name
  enriched.sort((a, b) => {
    const aName = (a.clientName || a.name || '').toLowerCase();
    const bName = (b.clientName || b.name || '').toLowerCase();
    return aName.localeCompare(bName);
  });
  
  const wrap = document.getElementById('client-table-wrap');
  if (enriched.length === 0) {
    wrap.innerHTML = '<div class="empty-state"><h3>No clients match</h3><p>Try adjusting the search or filter.</p></div>';
    return;
  }
  
  wrap.innerHTML = `
    <table class="client-table">
      <thead>
        <tr>
          <th>Priority</th>
          <th>Company</th>
          <th>Project / Engagement</th>
          <th>Account Manager</th>
          <th>DBAs Assigned</th>
          <th class="num">Hours</th>
          <th>Utilization</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        ${enriched.map(c => {
          const priority = c.status || 'unknown';
          const utilPct = c._utilization;
          const utilCls = c._healthStatus === 'over' ? 'over' : c._healthStatus === 'at-risk' ? 'high' : '';
          return `
            <tr>
              <td><span class="status-badge ${priority}">${priority}</span></td>
              <td><strong>${escapeHtml(c.clientName || '—')}</strong></td>
              <td>${escapeHtml(c.name)}</td>
              <td>${escapeHtml(c.owner || '—')}</td>
              <td>
                ${(c._effectiveAssignments && c._effectiveAssignments.length) 
                  ? `<div class="dba-list">${c._effectiveAssignments.map(d => `<span class="dba-tag">${escapeHtml(d)}</span>`).join('')}</div>`
                  : '<span style="color: var(--gray-mid); font-size: 0.85rem;">—</span>'}
              </td>
              <td class="num"><strong>${formatHours(c._hours)}</strong>${c._budget > 0 ? `<span style="color: var(--gray-mid); font-size: 0.78rem;"> / ${c._budget}</span>` : ''}</td>
              <td>
                ${utilPct !== null ? `
                  <div style="display: flex; align-items: center; gap: 8px;">
                    <div class="utilization-bar" style="max-width: 100px;"><div class="utilization-fill ${utilCls}" style="width: ${Math.min(utilPct, 100)}%"></div></div>
                    <span style="font-size: 0.82rem; color: var(--gray-text); white-space: nowrap;">${utilPct.toFixed(0)}%</span>
                  </div>
                ` : '<span style="color: var(--gray-mid); font-size: 0.85rem;">—</span>'}
              </td>
              <td><span class="health-badge ${c._healthStatus}">${c._healthLabel}</span></td>
            </tr>
          `;
        }).join('')}
      </tbody>
    </table>
    <div style="margin-top: 12px; padding: 12px; color: var(--gray-text); font-size: 0.82rem;">Hours and utilization reflect <strong>billable hours, current month (${appData.monthFrom || '—'} to ${appData.monthTo || '—'})</strong>. Sorted alphabetically by company.</div>
  `;
}

