function initDBAUI() {
  document.getElementById('dba-all-count').textContent = `(${dbaTeamData.length})`;
  document.getElementById('dba-search').addEventListener('input', applyDBAFilter);
  document.querySelectorAll('#dba-chips .dba-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('#dba-chips .dba-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      dbaFilter = chip.dataset.filter;
      applyDBAFilter();
    });
  });
  document.querySelectorAll('.dba-view-toggle button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.dba-view-toggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      dbaViewMode = btn.dataset.view;
      document.getElementById('dba-cards-view').style.display = dbaViewMode === 'cards' ? 'grid' : 'none';
      document.getElementById('dba-matrix-view').style.display = dbaViewMode === 'matrix' ? 'block' : 'none';
      applyDBAFilter();
    });
  });
  applyDBAFilter();
  renderCerts();
}

